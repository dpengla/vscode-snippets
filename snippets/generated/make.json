{
  "base": {
    "prefix": "base",
    "body": [
      ".PHONY: clean, mrproper",
      "CC = gcc",
      "CFLAGS = -g -Wall",
      "",
      "all: $1",
      "",
      "%.o: %.c",
      "\t\\$(CC) \\$(CFLAGS) -c -o \\$@ \\$<",
      "",
      "${1:out}: $1.o",
      "\t\\$(CC) \\$(CFLAGS) -o \\$@ \\$+",
      "",
      "clean:",
      "\trm -f *.o core.*",
      "",
      "mrproper: clean",
      "\trm -f $1"
    ],
    "description": "vim-snippets/make.snippets:2"
  },
  "add": {
    "prefix": "add",
    "body": [
      "${1:out}: $1.o",
      "\t\\$(CC) \\$(CFLAGS) -o \\$@ \\$+"
    ],
    "description": "vim-snippets/make.snippets:21"
  },
  "print": {
    "prefix": "print",
    "body": [
      "print-%: ; @echo \\$*=\\$(\\$*)"
    ],
    "description": "vim-snippets/make.snippets:25"
  },
  "if": {
    "prefix": "if",
    "body": [
      "ifeq (${1:cond0}, ${2:cond1})",
      "\t${0:${TM_SELECTED_TEXT}}",
      "endif"
    ],
    "description": "vim-snippets/make.snippets:28"
  },
  "ife": {
    "prefix": "ife",
    "body": [
      "ifeq (${1:cond0}, ${2:cond1})",
      "\t${3:${TM_SELECTED_TEXT}}",
      "else",
      "\t${0}",
      "endif"
    ],
    "description": "vim-snippets/make.snippets:33"
  },
  "el": {
    "prefix": "el",
    "body": [
      "else",
      "\t${0:${TM_SELECTED_TEXT}}"
    ],
    "description": "vim-snippets/make.snippets:40"
  },
  "default": {
    "prefix": "default",
    "body": [
      ".DEFAULT_GOAL := ${1}"
    ],
    "description": "vim-snippets/make.snippets:44"
  },
  "help": {
    "prefix": "help",
    "body": [
      "help: ## Prints help for targets with comments",
      "\t@cat \\$(MAKEFILE_LIST) | grep -E '^[a-zA-Z_-]+:.*?## .*\\$\\$' | awk 'BEGIN {FS = \":.*?## \"}; {printf \"\\033[36m%-30s\\033[0m %s\\n\", \\$\\$1, \\$\\$2}'",
      "${0}"
    ],
    "description": "vim-snippets/make.snippets:47"
  }
}
