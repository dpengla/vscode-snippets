      "title: ${1:title}",
      "layout: post",
      "date: ${2:date} ${0:hour:minute:second} -05:00",
      "---"
    ],
    "description": "vim-snippets/textile.snippets:2"
  },
  "img": {
    "prefix": "img",
    "body": [
      "!${1:url}(${2:title}):${0:link}!"
