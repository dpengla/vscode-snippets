  "genserver - basic genserver structure": {
    "prefix": "genserver",
    "body": [
      "use GenServer",
      "",
      "@doc false",
      "def start_link(init_args) do",
      "\tGenServer.start_link(__MODULE__, init_args, name: __MODULE__)",
      "end",
      "",
      "@impl true",
      "def init(state) do",
      "\t{:ok, state}",
      "end"
    ],
    "description": "basic genserver structure"
  },
  "super - basic supervisor structure": {
