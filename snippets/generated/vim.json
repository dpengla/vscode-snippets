{
  "header - standard Vim script file header": {
    "prefix": "header",
    "body": [
      "\" File: ${1:${TM_FILENAME_BASE}}",
      "\" Author: ${2:author}",
      "\" Description: ${3}",
      "${0:\" Last Modified: ${CURRENT_MONTH_NAME} ${CURRENT_DATE}, ${CURRENT_YEAR}}"
    ],
    "description": "standard Vim script file header"
  },
  "guard - script reload guard": {
    "prefix": "guard",
    "body": [
      "if exists('${1:did_${TM_FILENAME_BASE}}') || &cp${2: || version < 700}",
      "\tfinish",
      "endif",
      "let $1 = 1${0}"
    ],
    "description": "script reload guard"
  },
  "f - function": {
    "prefix": "f",
    "body": [
      "fun! ${1:${TM_FILENAME_BASE}}${2:function_name}(${3})",
      "\t${0}",
      "endf"
    ],
    "description": "function"
  },
  "t - try ... catch statement": {
    "prefix": "t",
    "body": [
      "try",
      "\t${1:${TM_SELECTED_TEXT}}",
      "catch ${2}",
      "\t${0}",
      "endtry"
    ],
    "description": "try ... catch statement"
  },
  "for - for ... in loop": {
    "prefix": "for",
    "body": [
      "for ${1} in ${2}",
      "\t${0:${TM_SELECTED_TEXT}}",
      "endfor"
    ],
    "description": "for ... in loop"
  },
  "forkv - for [key, value] in loop": {
    "prefix": "forkv",
    "body": [
      "for [${1},${2}] in items(${3})",
      "\t${0}",
      "\tunlet $1 $2",
      "endfor"
    ],
    "description": "for [key, value] in loop"
  },
  "wh - while loop": {
    "prefix": "wh",
    "body": [
      "while ${1}",
      "\t${0:${TM_SELECTED_TEXT}}",
      "endw"
    ],
    "description": "while loop"
  },
  "if - if statement": {
    "prefix": "if",
    "body": [
      "if ${1}",
      "\t${0:${TM_SELECTED_TEXT}}",
      "endif"
    ],
    "description": "if statement"
  },
  "ife - if ... else statement": {
    "prefix": "ife",
    "body": [
      "if ${1}",
      "\t${2:${TM_SELECTED_TEXT}}",
      "else",
      "\t${0}",
      "endif"
    ],
    "description": "if ... else statement"
  },
  "au - augroup ... autocmd block": {
    "prefix": "au",
    "body": [
      "augroup ${1:AU_NAME}",
      "\tautocmd!",
      "\tautocmd ${2:BufRead,BufNewFile} ${3:*.ext,*.ext3|<buffer[=N]>} ${0}",
      "augroup END"
    ],
    "description": "augroup ... autocmd block"
  },
  "auv - augroupvisual ... autocmd block with visual placeholder": {
    "prefix": "auv",
    "body": [
      "augroup ${1:AU_NAME}",
      "\tautocmd!",
      "\t${0:${TM_SELECTED_TEXT}}",
      "augroup END"
    ],
    "description": "augroupvisual ... autocmd block with visual placeholder"
  },
  "bun - Vundle.vim Plugin definition": {
    "prefix": "bun",
    "body": [
      "Plugin '${0}'"
    ],
    "description": "Vundle.vim Plugin definition"
  },
  "plug - vim-plug Plugin definition": {
    "prefix": "plug",
    "body": [
      "Plug '${0}'"
    ],
    "description": "vim-plug Plugin definition"
  },
  "plugdo - vim-plug Plugin definition with { 'do': '' }": {
    "prefix": "plugdo",
    "body": [
      "Plug '${1}', { 'do': '${0}' }"
    ],
    "description": "vim-plug Plugin definition with { 'do': '' }"
  },
  "plugon - vim-plug Plugin definition with { 'on': '' }": {
    "prefix": "plugon",
    "body": [
      "Plug '${1}', { 'on': '${0}' }"
    ],
    "description": "vim-plug Plugin definition with { 'on': '' }"
  },
  "plugfor - vim-plug Plugin definition with { 'for': '' }": {
    "prefix": "plugfor",
    "body": [
      "Plug '${1}', { 'for': '${0}' }"
    ],
    "description": "vim-plug Plugin definition with { 'for': '' }"
  },
  "plugbr - vim-plug Plugin definition with { 'branch': '' }": {
    "prefix": "plugbr",
    "body": [
      "Plug '${1}', { 'branch': '${0}' }"
    ],
    "description": "vim-plug Plugin definition with { 'branch': '' }"
  },
  "plugtag - vim-plug Plugin definition with { 'tag': '' }": {
    "prefix": "plugtag",
    "body": [
      "Plug '${1}', { 'tag': '${0}' }"
    ],
    "description": "vim-plug Plugin definition with { 'tag': '' }"
  },
  "let": {
    "prefix": "let",
    "body": [
      "let ${1:variable} = ${0: value}"
    ],
    "description": "vim-snippets/vim.snippets:68"
  },
  "se": {
    "prefix": "se",
    "body": [
      "set ${1:setting};"
    ],
    "description": "vim-snippets/vim.snippets:70"
  },
  "set": {
    "prefix": "set",
    "body": [
      "set ${1:setting} = ${0:value}"
    ],
    "description": "vim-snippets/vim.snippets:72"
  },
  "nn": {
    "prefix": "nn",
    "body": [
      "nnoremap ${1} ${2}<CR>"
    ],
    "description": "vim-snippets/vim.snippets:74"
  },
  "no": {
    "prefix": "no",
    "body": [
      "noremap ${1} ${2}"
    ],
    "description": "vim-snippets/vim.snippets:76"
  },
  "vm": {
    "prefix": "vm",
    "body": [
      "vmap ${1} ${2}"
    ],
    "description": "vim-snippets/vim.snippets:78"
  },
  "im": {
    "prefix": "im",
    "body": [
      "imap ${1} ${2}"
    ],
    "description": "vim-snippets/vim.snippets:80"
  },
  "exe": {
    "prefix": "exe",
    "body": [
      "execute ${1}"
    ],
    "description": "vim-snippets/vim.snippets:82"
  },
  "filename": {
    "prefix": "filename",
    "body": [
      "${TM_FILENAME_BASE}"
    ],
    "description": "vim-snippets/vim.snippets:84"
  }
}
