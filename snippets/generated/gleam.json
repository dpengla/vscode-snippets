{
  "fn - fn": {
    "prefix": "fn",
    "body": [
      "fn ${1:function_name}(${2}) -> ${3:Nil} {",
      "  ${0:\\${VISUAL:todo}}",
      "}"
    ],
    "description": "fn"
  },
