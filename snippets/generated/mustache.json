{
  "if - # {{#value}} ... {{/value}}": {
    "prefix": "if",
    "body": [
      "{{#${1:value}}}",
      "${0:${TM_SELECTED_TEXT}}",
      "{{/$1}}"
    ],
    "description": "# {{#value}} ... {{/value}}"
  },
  "ifn - # {{^value}} ... {{/value}}": {
    "prefix": "ifn",
    "body": [
      "{{^${1:value}}}",
      "${0:${TM_SELECTED_TEXT}}",
      "{{/$1}}"
    ],
    "description": "# {{^value}} ... {{/value}}"
  },
  "ife - # {{#value}} ... {{/value}} {{^value}} ... {{/value}}": {
    "prefix": "ife",
    "body": [
      "{{#${1:value}}}",
      "${2:${TM_SELECTED_TEXT}}",
      "{{/$1}}",
      "{{^$1}}",
      "${3}",
      "{{/$1}}"
    ],
    "description": "# {{#value}} ... {{/value}} {{^value}} ... {{/value}}"
  }
}
