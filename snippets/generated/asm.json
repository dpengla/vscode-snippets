{
  "scode - Start basic code for assembly": {
    "prefix": "scode",
    "body": [
      ".data",
      "",
      "",
      ".text",
      "",
      "",
      ".global main",
      "",
      "",
      "main:"
    ],
    "description": "Start basic code for assembly"
  },
  "scodes - Start basic code for assembly with _start label": {
    "prefix": "scodes",
    "body": [
      ".data",
      "",
      "",
      ".text",
      "",
      "",
      ".globl _start",
      "",
      "",
      "_start:"
    ],
    "description": "Start basic code for assembly with _start label"
  },
  "lo - Long": {
    "prefix": "lo",
    "body": [
      "$1: .long $2"
    ],
    "description": "Long"
  },
  "wo - Word": {
    "prefix": "wo",
    "body": [
      "$1: .word $2"
    ],
    "description": "Word"
  },
  "by - Byte": {
    "prefix": "by",
    "body": [
      "$1: .byte $2"
    ],
    "description": "Byte"
  },
  "sp - Space": {
    "prefix": "sp",
    "body": [
      "$1: .space $2"
    ],
    "description": "Space"
  },
  "ai - Ascii": {
    "prefix": "ai",
    "body": [
      "$1: .ascii \"$2\""
    ],
    "description": "Ascii"
  },
  "az - Asciz": {
    "prefix": "az",
    "body": [
      "$1: .asciz \"$2\""
    ],
    "description": "Asciz"
  },
  "ze - Zero": {
    "prefix": "ze",
    "body": [
      "$1: .zero \"$2\""
    ],
    "description": "Zero"
  },
  "qu - Quad": {
    "prefix": "qu",
    "body": [
      "$1: .quad \"$2\""
    ],
    "description": "Quad"
  },
  "si - Single": {
    "prefix": "si",
    "body": [
      "$1: .single \"$2\""
    ],
    "description": "Single"
  },
  "do - Double": {
    "prefix": "do",
    "body": [
      "$1: .single \"$2\""
    ],
    "description": "Double"
  },
  "fl - Float": {
    "prefix": "fl",
    "body": [
      "$1: .single \"$2\""
    ],
    "description": "Float"
  },
  "oc - Octa": {
    "prefix": "oc",
    "body": [
      "$1: .single \"$2\""
    ],
    "description": "Octa"
  },
  "sh - Short": {
    "prefix": "sh",
    "body": [
      "$1: .single \"$2\""
    ],
    "description": "Short"
  },
  "exit0 - Exit without error": {
    "prefix": "exit0",
    "body": [
      "movl \\$1, %eax",
      "xorl %ebx, %ebx",
      "int \\$0x80"
    ],
    "description": "Exit without error"
  },
  "exit - Exit with error": {
    "prefix": "exit",
    "body": [
      "mov \\$1, %eax",
      "mov $1, %ebx",
      "int \\$0x80"
    ],
    "description": "Exit with error"
  },
  "readfstdin - Read fixed length text from stdin": {
    "prefix": "readfstdin",
    "body": [
      "mov \\$3, %eax",
      "mov \\$2, %ebx",
      "mov $1, %ecx",
      "mov $2, %edx",
      "int \\$0x80"
    ],
    "description": "Read fixed length text from stdin"
  },
  "writestdout - Write text to stdout": {
    "prefix": "writestdout",
    "body": [
      "mov \\$4, %eax",
      "mov \\$1, %ebx",
      "mov $1, %ecx",
      "mov $2, %edx",
      "int \\$0x80"
    ],
    "description": "Write text to stdout"
  },
  "writestderr - Write text to stderr": {
    "prefix": "writestderr",
    "body": [
      "mov \\$4, %eax",
      "mov \\$2, %ebx",
      "mov $1, %ecx",
      "mov $2, %edx",
      "int \\$0x80"
    ],
    "description": "Write text to stderr"
  },
  "* - Multiplication": {
    "prefix": "*",
    "body": [
      "mov $1, %eax",
      "mul $2"
    ],
    "description": "Multiplication"
  },
  "/ - Division": {
    "prefix": "/",
    "body": [
      "mov $1, %eax",
      "div $2"
    ],
    "description": "Division"
  },
  "jmpl - Conditional lower jump": {
    "prefix": "jmpl",
    "body": [
      "cmp $1, $2",
      "jl $3 "
    ],
    "description": "Conditional lower jump"
  },
  "jmple - Conditional lower or equal jump": {
    "prefix": "jmple",
    "body": [
      "cmp $1, $2",
      "jle $3 "
    ],
    "description": "Conditional lower or equal jump"
  },
  "jmpe - Conditional equal jump": {
    "prefix": "jmpe",
    "body": [
      "cmp $1, $2",
      "je $3 "
    ],
    "description": "Conditional equal jump"
  },
  "jmpn - Conditional not equal jump": {
    "prefix": "jmpn",
    "body": [
      "cmp $1, $2",
      "jn $3"
    ],
    "description": "Conditional not equal jump"
  },
  "jmpg - Conditional greater jump": {
    "prefix": "jmpg",
    "body": [
      "cmp $1, $2",
      "jg $3"
    ],
    "description": "Conditional greater jump"
  },
  "jmpge - Conditional greater or equal jump": {
    "prefix": "jmpge",
    "body": [
      "cmp $1, $2",
      "je $3"
    ],
    "description": "Conditional greater or equal jump"
  },
  "loopn - Loop n times": {
    "prefix": "loopn",
    "body": [
      "mov $1, %ecx",
      "",
      "et_for:",
      "\t$2",
      "",
      "\tloop et_for"
    ],
    "description": "Loop n times"
  },
  "loopnn - Loop n-1 times": {
    "prefix": "loopnn",
    "body": [
      "mov $1, %ecx",
      "dec %ecx",
      "",
      "et_for:",
      "\t$2",
      "",
      "\tloop et_for"
    ],
    "description": "Loop n-1 times"
  },
  "loopv - Loop through a vector": {
    "prefix": "loopv",
    "body": [
      "lea $1, %edi",
      "xor %ecx, %ecx",
      "",
      "et_for:",
      "\tcmp %ecx, $2",
      "\tje $3",
      "",
      "\t$4",
      "",
      "\tinc %ecx",
      "\tjmp et_for"
    ],
    "description": "Loop through a vector"
  },
  "mul - Multiply": {
    "prefix": "mul",
    "body": [
      "xor %edx, %edx",
      "mov $1, %eax",
      "mul $2"
    ],
    "description": "Multiply"
  },
  "mul64 - Multiply numbers greater than 2^32": {
    "prefix": "mul64",
    "body": [
      "mov $1, %edx",
      "mov $2, %eax",
      "mul $3"
    ],
    "description": "Multiply numbers greater than 2^32"
  },
  "div - Divide": {
    "prefix": "div",
    "body": [
      "xor %edx, %edx",
      "mov $1, %eax",
      "div $2"
    ],
    "description": "Divide"
  },
  "div64 - Divide numbers greater than 2^32": {
    "prefix": "div64",
    "body": [
      "mov $1, %edx",
      "mov $2, %eax",
      "div $3"
    ],
    "description": "Divide numbers greater than 2^32"
  },
  "pr - Call printf": {
    "prefix": "pr",
    "body": [
      "pushl $1",
      "call printf",
      "popl $2"
    ],
    "description": "Call printf"
  },
  "sc - Call scanf": {
    "prefix": "sc",
    "body": [
      "pushl $1",
      "call scanf",
      "popl $2"
    ],
    "description": "Call scanf"
  },
  "mindex - Current index from a matrix": {
    "prefix": "mindex",
    "body": [
      "xor %edx, %edx",
      "movl $1, %eax",
      "mull $2",
      "addl $3, %eax"
    ],
    "description": "Current index from a matrix"
  },
  "ffl - Call fflush": {
    "prefix": "ffl",
    "body": [
      "pushl \\$0",
      "call fflush",
      "popl $1"
    ],
    "description": "Call fflush"
  },
  "at - Call atoi": {
    "prefix": "at",
    "body": [
      "pushl $1",
      "call atoi",
      "popl $2"
    ],
    "description": "Call atoi"
  },
  "len - Call strlen": {
    "prefix": "len",
    "body": [
      "pushl $1",
      "call strlen",
      "popl $2"
    ],
    "description": "Call strlen"
  },
  "proc - Basic procedure": {
    "prefix": "proc",
    "body": [
      "$1:",
      "pushl %ebp",
      "movl %esp, %ebp",
      "",
      "$2",
      "",
      "popl %ebp",
      "ret"
    ],
    "description": "Basic procedure"
  }
}
