{
  "classheader": {
    "prefix": "classheader",
    "body": [
      "# ${1:${TM_FILENAME_BASE}}",
      "# ${2:A description of what this class does}",
      "#",
      "# @summary ${3:A short summary of the purpose of this class}",
      "#",
      "# @param ${4:parameter1}",
      "#   ${6:Explanation of what this parameter affects.}",
      "#",
      "# @example Simple use",
      "#   include $1",
      "#",
      "# @example Use with params",
      "#   class { '$1':",
      "#     \\$$4 => '${7:undef}',",
      "#   }",
      "#",
      "# @author ${8:author} <${9:email}>",
      "#",
      "# @note Copyright ${CURRENT_YEAR} $8",
      "#",
      "class $1(",
      "\t${5:String} \\$$4 = undef,",
      ") {",
      "\t${0}",
      "}"
    ],
    "description": "vim-snippets/puppet.snippets:9"
  },
  "defheader": {
    "prefix": "defheader",
    "body": [
      "# ${1:${TM_FILENAME_BASE}}",
      "# ${2:A description of what this define does}",
      "#",
      "# @summary ${3:A short summary of the purpose of this define}",
      "#",
      "# @param ${4:parameter1} [${5:String}]",
      "#   ${6:Explanation of what this parameter affects.}",
      "#",
      "# @example Simple use",
      "#   $1 { 'namevar':",
      "#     \\$$4 => '${7:undef}',",
      "#   }",
      "#",
      "# @author ${8:author} <${9:email}>",
      "#",
      "# @note Copyright ${CURRENT_YEAR} $8",
      "#",
      "define $1(",
      "\t\\$$4 = undef,",
      ") {",
      "\t${0}",
      "}"
    ],
    "description": "vim-snippets/puppet.snippets:36"
  },
  "class": {
    "prefix": "class",
    "body": [
      "class ${1:${TM_FILENAME_BASE}} {",
      "\t${0}",
      "}"
    ],
    "description": "vim-snippets/puppet.snippets:61"
  },
  "node": {
    "prefix": "node",
    "body": [
      "node \"${1:${TM_FILENAME_BASE}}\" {",
      "\t${0}",
      "}"
    ],
    "description": "vim-snippets/puppet.snippets:65"
  },
  "case": {
    "prefix": "case",
    "body": [
      "case \\$${1:variable} {",
      "\tdefault: { ${0} }",
      "}"
    ],
    "description": "vim-snippets/puppet.snippets:69"
  },
  "ife": {
    "prefix": "ife",
    "body": [
      "if \\$${1:variable} {",
      "\t${2}",
      "} else {",
      "\t${0}",
      "}"
    ],
    "description": "vim-snippets/puppet.snippets:73"
  },
  "if": {
    "prefix": "if",
    "body": [
      "if \\$${1:variable} {",
      "\t${0}",
      "}"
    ],
    "description": "vim-snippets/puppet.snippets:79"
  },
  "ifd": {
    "prefix": "ifd",
    "body": [
      "if defined(${1:Resource}[\"${2:name}\"]) {",
      "\t${0}",
      "}"
    ],
    "description": "vim-snippets/puppet.snippets:83"
  },
  "ifnd": {
    "prefix": "ifnd",
    "body": [
      "if !defined(${1:Resource}[\"${2:name}\"]) {",
      "\t${0}",
      "}"
    ],
    "description": "vim-snippets/puppet.snippets:87"
  },
  "el": {
    "prefix": "el",
    "body": [
      "else {",
      "\t${0}",
      "}"
    ],
    "description": "vim-snippets/puppet.snippets:91"
  },
  "?": {
    "prefix": "?",
    "body": [
      "? {",
      "\t\"${1}\"\t=> ${0}",
      "  }"
    ],
    "description": "vim-snippets/puppet.snippets:95"
  },
  "[": {
    "prefix": "[",
    "body": [
      "[ ${1} ]"
    ],
    "description": "vim-snippets/puppet.snippets:101"
  },
  ">": {
    "prefix": ">",
    "body": [
      "${1}\t=> ${0}"
    ],
    "description": "vim-snippets/puppet.snippets:103"
  },
  "p:": {
    "prefix": "p:",
    "body": [
      "\"puppet://puppet/${1:module name}/${0:file name}\""
    ],
    "description": "vim-snippets/puppet.snippets:105"
  },
  "alert": {
    "prefix": "alert",
    "body": [
      "alert(\"${1:message}\")"
    ],
    "description": "vim-snippets/puppet.snippets:109"
  },
  "crit": {
    "prefix": "crit",
    "body": [
      "crit(\"${1:message}\")"
    ],
    "description": "vim-snippets/puppet.snippets:111"
  },
  "debug": {
    "prefix": "debug",
    "body": [
      "debug(\"${1:message}\")"
    ],
    "description": "vim-snippets/puppet.snippets:113"
  },
  "defined": {
    "prefix": "defined",
    "body": [
      "defined(${1:Resource}[\"${2:name}\"])"
    ],
    "description": "vim-snippets/puppet.snippets:115"
  },
  "emerg": {
    "prefix": "emerg",
    "body": [
      "emerg(\"${1:message}\")"
    ],
    "description": "vim-snippets/puppet.snippets:117"
  },
  "extlookup - Simple extlookup": {
    "prefix": "extlookup",
    "body": [
      "extlookup(\"${1:variable}\")"
    ],
    "description": "Simple extlookup"
  },
  "extlookup - Extlookup with defaults": {
    "prefix": "extlookup",
    "body": [
      "extlookup(\"${1:variable}\", \"${2:default}\")"
    ],
    "description": "Extlookup with defaults"
  },
  "extlookup - Extlookup with defaults and custom data file": {
    "prefix": "extlookup",
    "body": [
      "extlookup(\"${1:variable}\", \"${2:default}\", \"${3:data source}\")"
    ],
    "description": "Extlookup with defaults and custom data file"
  },
  "fail": {
    "prefix": "fail",
    "body": [
      "fail(\"${1:message}\")"
    ],
    "description": "vim-snippets/puppet.snippets:125"
  },
  "info": {
    "prefix": "info",
    "body": [
      "info(\"${1:message}\")"
    ],
    "description": "vim-snippets/puppet.snippets:127"
  },
  "inline_template": {
    "prefix": "inline_template",
    "body": [
      "inline_template(\"<%= ${1} %>\")"
    ],
    "description": "vim-snippets/puppet.snippets:129"
  },
  "notice": {
    "prefix": "notice",
    "body": [
      "notice(\"${1:message}\")"
    ],
    "description": "vim-snippets/puppet.snippets:131"
  },
  "realize": {
    "prefix": "realize",
    "body": [
      "realize(${1:Resource}[${2:name}])"
    ],
    "description": "vim-snippets/puppet.snippets:133"
  },
  "regsubst": {
    "prefix": "regsubst",
    "body": [
      "regsubst(${1:hay stack}, ${2:needle}, \"${3:replacement}\")"
    ],
    "description": "vim-snippets/puppet.snippets:135"
  },
  "inc": {
    "prefix": "inc",
    "body": [
      "include ${1:classname}"
    ],
    "description": "vim-snippets/puppet.snippets:137"
  },
  "split": {
    "prefix": "split",
    "body": [
      "split(${1:hay stack}, \"${2:patten}\")"
    ],
    "description": "vim-snippets/puppet.snippets:139"
  },
  "versioncmp": {
    "prefix": "versioncmp",
    "body": [
      "versioncmp(\"${1:version}\", \"${2:version}\")"
    ],
    "description": "vim-snippets/puppet.snippets:141"
  },
  "warning": {
    "prefix": "warning",
    "body": [
      "warning(\"${1:message}\")"
    ],
    "description": "vim-snippets/puppet.snippets:143"
  },
  "cron": {
    "prefix": "cron",
    "body": [
      "cron { \"${1:name}\":",
      "\tcommand => \"${2}\",",
      "\tuser    => \"${3:root}\",",
      "\t${4}    => ${0},",
      "}"
    ],
    "description": "vim-snippets/puppet.snippets:147"
  },
  "exec": {
    "prefix": "exec",
    "body": [
      "exec { \"${1:name}\":",
      "\tcommand => \"${2:$1}\",",
      "\tuser    => \"${3:root}\",",
      "\t${4}    => ${0},",
      "}"
    ],
    "description": "vim-snippets/puppet.snippets:154"
  },
  "user": {
    "prefix": "user",
    "body": [
      "user { \"${1:user}\":",
      "\tensure      => present,",
      "\tcomment     => \"${2:$1}\",",
      "\tmanagehome  => true,",
      "\thome        => \"${0:/home/$1}\",",
      "}"
    ],
    "description": "vim-snippets/puppet.snippets:161"
  },
  "group": {
    "prefix": "group",
    "body": [
      "group { \"${1:group}\":",
      "\tensure => ${0:present},",
      "}"
    ],
    "description": "vim-snippets/puppet.snippets:169"
  },
  "host": {
    "prefix": "host",
    "body": [
      "host { \"${1:hostname}\":",
      "\tip => ${0:127.0.0.1},",
      "}"
    ],
    "description": "vim-snippets/puppet.snippets:174"
  },
  "mailalias": {
    "prefix": "mailalias",
    "body": [
      "mailalias { \"${1:localpart}\":",
      "\trecipient => \"${0:recipient}\",",
      "}"
    ],
    "description": "vim-snippets/puppet.snippets:179"
  },
  "mount": {
    "prefix": "mount",
    "body": [
      "mount { \"${1:destination path}\":",
      "\tensure\t=> ${2:mounted},",
      "\tdevice\t=> \"${0:device name or path}\",",
      "}"
    ],
    "description": "vim-snippets/puppet.snippets:184"
  },
  "notify": {
    "prefix": "notify",
    "body": [
      "notify { \"${1:message}\": }"
    ],
    "description": "vim-snippets/puppet.snippets:190"
  },
  "package": {
    "prefix": "package",
    "body": [
      "package { \"${1:package name}\":",
      "\tensure\t=> ${0:present},",
      "}"
    ],
    "description": "vim-snippets/puppet.snippets:193"
  },
  "yumrepo": {
    "prefix": "yumrepo",
    "body": [
      "yumrepo { \"${1:repo name}\":",
      "\tdescr   => \"${2:$1}\",",
      "\tenabled => ${0:1},",
      "}"
    ],
    "description": "vim-snippets/puppet.snippets:198"
  },
  "define": {
    "prefix": "define",
    "body": [
      "define ${1} (${2}) {",
      "\t${0}",
      "}"
    ],
    "description": "vim-snippets/puppet.snippets:204"
  },
  "service": {
    "prefix": "service",
    "body": [
      "service { \"${1:service}\":",
      "\tensure    => running,",
      "\tenable    => true,",
      "\trequire   => [ Package[\"${2:package}\"], File[\"${3:file}\"], ],",
      "\tsubscribe => [ File[\"${4:configfile1}\"], File[\"${5:configfile2}\"], Package[\"${6:package}\"], ],",
      "}"
    ],
    "description": "vim-snippets/puppet.snippets:209"
  },
  "file": {
    "prefix": "file",
    "body": [
      "file { \"${1:filename}\":",
      "\tensure  => ${2:present},",
      "\towner   => \"${3:root}\",",
      "\tgroup   => \"${4:root}\",",
      "\tmode    => \"${5:0644}\",",
      "\tsource  => \"puppet:///modules/${6:module}/${7:source}\",",
      "\tcontent => template(\"${8:module}/${9:template}\"),",
      "\talias   => \"${10:alias}\",",
      "\trequire => [ Package[\"${11:package}\"], File[\"${12:file}\"], ],",
      "}"
    ],
    "description": "vim-snippets/puppet.snippets:217"
  },
  "archive": {
    "prefix": "archive",
    "body": [
      "archive { \"${1:filename}\":",
      "\tensure     => ${2:present},",
      "\turl        => \"http://${3:url}\",",
      "\textension  => \"${4:tgz}\",",
      "\ttarget     => \"${5:target}\",",
      "\tchecksum   => ${6:false},",
      "\tsrc_target => \"${7:/tmp}\",",
      "}"
    ],
    "description": "vim-snippets/puppet.snippets:229"
  },
  "firewall": {
    "prefix": "firewall",
    "body": [
      "firewall { \"${1:comment}\":",
      "\tproto\t=> ${2:tcp},",
      "\taction\t=> ${3:accept},",
      "\tport\t=> ${4},",
      "}"
    ],
    "description": "vim-snippets/puppet.snippets:239"
  }
}
