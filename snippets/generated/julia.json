{
  "#!": {
    "prefix": "#!",
    "body": [
      "#!/usr/bin/env julia"
    ],
    "description": "vim-snippets/julia.snippets:1"
  },
  "fun - function definition": {
    "prefix": "fun",
    "body": [
      "function ${1}(${2})",
      "\t${0}",
      "end"
    ],
    "description": "function definition"
  },
  "ret - return": {
    "prefix": "ret",
    "body": [
      "return(${0})"
    ],
    "description": "return"
  },
  "pr - print": {
    "prefix": "pr",
    "body": [
      "print(\"${1}\")",
      "${0}"
    ],
    "description": "print"
  },
  "prl - print line": {
    "prefix": "prl",
    "body": [
      "println(\"${1}\")",
      "${0}"
    ],
    "description": "print line"
  },
  "use - load a package": {
    "prefix": "use",
    "body": [
      "using ${0}"
    ],
    "description": "load a package"
  },
  "incl - include source code": {
    "prefix": "incl",
    "body": [
      "include(\"${1}\")",
      "${0}"
    ],
    "description": "include source code"
  },
  "forc - for loop iterating over iterable container": {
    "prefix": "forc",
    "body": [
      "for ${1} in ${2}",
      "\t${0}",
      "end"
    ],
    "description": "for loop iterating over iterable container"
  },
  "for - standard for loop": {
    "prefix": "for",
    "body": [
      "for ${1} = ${2}",
      "\t${0}",
      "end"
    ],
    "description": "standard for loop"
  },
  "fornest - nested for loop": {
    "prefix": "fornest",
    "body": [
