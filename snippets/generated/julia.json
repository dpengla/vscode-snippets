      "\t${0}",
      "end"
    ],
    "description": "nested for loop"
  },
  "wh - while loop": {
    "prefix": "wh",
    "body": [
      "while ${1} ${2:<=} ${3}",
      "\t${0}",
      "end"
    ],
    "description": "while loop"
  },
  "if - if statement": {
    "prefix": "if",
    "body": [
      "if ${1}",
