  "element": {
    "prefix": "element",
    "body": [
      "module Main exposing (Model, Msg(..), init, main, subscriptions, update, view)",
      "",
      "import Browser",
      "import Html exposing (..)",
      "import Json.Encode",
      "",
      "",
      "main : Program Flags Model Msg",
      "main =",
      "\tBrowser.element",
      "\t\t{ init = init",
      "\t\t, update = update",
      "\t\t, subscriptions = subscriptions",
      "\t\t, view = view",
      "\t\t}",
      "",
      "",
      "type alias Model =",
      "\t{}",
      "",
      "",
      "type alias Flags =",
      "\tJson.Encode.Value",
      "",
      "",
      "init : Flags -> ( Model, Cmd Msg )",
      "init flags_ =",
      "\t( {}",
      "\t, Cmd.none",
      "\t)",
      "",
      "",
      "type Msg",
      "\t= Noop",
      "",
      "",
      "update : Msg -> Model -> ( Model, Cmd Msg )",
      "update msg model =",
      "\tcase msg of",
      "\t\tNoop ->",
      "\t\t\t( model",
      "\t\t\t, Cmd.none",
      "\t\t\t)",
      "",
      "",
      "subscriptions : Model -> Sub Msg",
      "subscriptions model =",
      "\tSub.none",
      "",
      "",
      "view : Model -> Html Msg",
      "view model =",
      "\th1 [] [ text \"Hello, world!\" ]"
    ],
    "description": "vim-snippets/elm.snippets:105"
